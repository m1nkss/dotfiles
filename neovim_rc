" --- Options de base ---
set number
set cursorline
set shiftwidth=4
set tabstop=4
set noexpandtab
set nobackup
set noswapfile
set nowrap
set wildmenu
set mouse=
syntax on
filetype plugin indent on
highlight cursorLine ctermbg=237
colorscheme zenburn
set hlsearch
set incsearch
set lazyredraw

" --- Leader & Raccourcis ---
let mapleader="ù"
nnoremap <leader>d :vsp<CR>
nnoremap <leader>e <C-W><C-W>
nnoremap <leader>t :tabe<CR>
nnoremap <leader>ff :Files<CR>

" --- Plugins ---
call plug#begin('~/.vim/plugged')
    Plug 'raimondi/delimitmate'
    Plug 'tpope/vim-sensible'
    Plug 'dense-analysis/ale'
    Plug 'junegunn/fzf.vim'
    Plug 'jnurmine/Zenburn'
call plug#end()

" --- Auto Header 42 (si fichier C dans cursus42) ---
autocmd BufRead,BufNewFile *.c if expand('%:p:h') =~ 'cursus42' | execute 'Stdheader' | endif

" --- ALE config ---
let g:ale_linters = {'c': ['clang'], 'cpp': ['clang']}
let g:ale_fixers = {'c': ['clang-format']}

" --- Infos user 42 ---
let g:user42 = 'mameerbe'
let g:mail42 = 'mameerbe@student.42.fr'
